<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ui.PopUpFinalPartidaController"
           fx:id="rootPopup"
           style="-fx-background-color: rgba(0,0,0,0.6);">

    <!-- CONTENEDOR CENTRAL -->
    <VBox fx:id="popupBox"
          alignment="CENTER"
          spacing="25"
          style="-fx-background-color: #1e1e1e;
                 -fx-background-radius: 20;
                 -fx-padding: 30;">

        <!-- IMAGEN SUPERIOR (TROFEO / BANNER FINAL) -->
        <ImageView fx:id="imgTitulo"
                   fitWidth="320"
                   preserveRatio="true"/>

        <!-- TÍTULO -->
        <Label fx:id="lblTitulo"
               text="¡La partida ha terminado!"
               textAlignment="CENTER"
               alignment="CENTER"
               style="-fx-text-fill: white;
                      -fx-font-size: 26px;
                      -fx-font-weight: bold;"/>

        <!-- TEXTO GANADOR -->
        <Label fx:id="lblGanador"
               text="Ganador: Nombre (0 pescaitos)"
               wrapText="true"
               maxWidth="450"
               textAlignment="CENTER"
               alignment="CENTER"
               style="-fx-text-fill: white;
                      -fx-font-size: 20px;"/>

        <HBox alignment="CENTER" spacing="40">

            <Button fx:id="btnIrSala"
                    onAction="#onIrSala"
                    style="-fx-background-color: transparent; -fx-padding: 0;">
                <graphic>
                    <ImageView fx:id="imgIrSala"
                               fitWidth="200"
                               preserveRatio="true"/>
                </graphic>
            </Button>

            <Button fx:id="btnVolverJugar"
                    onAction="#onVolverJugar"
                    style="-fx-background-color: transparent; -fx-padding: 0;">
                <graphic>
                    <ImageView fx:id="imgVolverJugar"
                               fitWidth="200"
                               preserveRatio="true"/>
                </graphic>
            </Button>

        </HBox>

    </VBox>

</StackPane>

